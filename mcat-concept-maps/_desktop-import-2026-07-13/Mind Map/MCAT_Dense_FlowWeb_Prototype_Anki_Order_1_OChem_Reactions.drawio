        <mxCell id="center" value="Dense Flow-Web Prototype — Anki Order 1
MCATalyst OChem Reactions" parent="layer1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b38b00;fontFamily=Verdana;fontSize=18;strokeWidth=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1"><mxGeometry x="900" y="520" width="330" height="95" as="geometry"/></mxCell>
        <mxCell id="sn" value="Substitution reactions compare mechanism, rate law, substrate, solvent, and stereochemistry." parent="layer1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b38b00;fontFamily=Verdana;fontSize=13;strokeWidth=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1"><mxGeometry x="80" y="80" width="360" height="75" as="geometry"/></mxCell>
        <mxCell id="sn1" value="SN1 is unimolecular and forms a carbocation intermediate." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4d6;strokeColor=#c65911;fontFamily=Verdana;fontSize=12;strokeWidth=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1"><mxGeometry x="90" y="210" width="290" height="60" as="geometry"/></mxCell>
        <mxCell id="sn2" value="SN2 is bimolecular and has one concerted transition state." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4d6;strokeColor=#c65911;fontFamily=Verdana;fontSize=12;strokeWidth=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1"><mxGeometry x="90" y="500" width="290" height="60" as="geometry"/></mxCell>
        <mxCell id="sn1_rate" value="SN1 rate depends only on the leaving group/substrate concentration." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#0066cc;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="440" y="150" width="330" height="52" as="geometry"/></mxCell>
        <mxCell id="sn1_step" value="SN1 rate-limiting step is the leaving group leaving." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#0066cc;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="440" y="220" width="330" height="52" as="geometry"/></mxCell>
        <mxCell id="sn1_sub" value="SN1 prefers more substituted carbons because carbocations are stabilized." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#0066cc;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="440" y="290" width="330" height="52" as="geometry"/></mxCell>
        <mxCell id="sn1_solvent" value="SN1 prefers polar protic solvent because ions are stabilized." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#0066cc;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="440" y="360" width="330" height="52" as="geometry"/></mxCell>
        <mxCell id="sn1_stereo" value="SN1 can form a racemic mixture because the carbocation is planar." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#0066cc;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="440" y="430" width="330" height="52" as="geometry"/></mxCell>
        <mxCell id="sn2_rate" value="SN2 rate depends on both substrate and nucleophile concentration." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#0066cc;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="440" y="520" width="330" height="52" as="geometry"/></mxCell>
        <mxCell id="sn2_step" value="SN2 occurs in one step: attack and leaving-group departure happen together." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#0066cc;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="440" y="590" width="330" height="52" as="geometry"/></mxCell>
        <mxCell id="sn2_sub" value="SN2 prefers less substituted carbons because steric hindrance blocks backside attack." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#0066cc;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="440" y="660" width="330" height="52" as="geometry"/></mxCell>
        <mxCell id="sn2_solvent" value="SN2 prefers polar aprotic solvent because the nucleophile stays reactive." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#0066cc;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="440" y="730" width="330" height="52" as="geometry"/></mxCell>
        <mxCell id="sn2_stereo" value="SN2 causes inversion of stereochemistry by backside attack." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#0066cc;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="440" y="800" width="330" height="52" as="geometry"/></mxCell>
        <mxCell id="elim" value="Elimination reactions parallel substitution logic but produce alkenes." parent="layer1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b38b00;fontFamily=Verdana;fontSize=13;strokeWidth=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1"><mxGeometry x="80" y="990" width="360" height="70" as="geometry"/></mxCell>
        <mxCell id="e1" value="E1 behaves like SN1 because both form carbocation intermediates." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4d6;strokeColor=#c65911;fontFamily=Verdana;fontSize=12;strokeWidth=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1"><mxGeometry x="440" y="930" width="330" height="55" as="geometry"/></mxCell>
        <mxCell id="e2" value="E2 behaves like SN2 because both are concerted and substrate/base-dependent." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4d6;strokeColor=#c65911;fontFamily=Verdana;fontSize=12;strokeWidth=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1"><mxGeometry x="440" y="1010" width="330" height="60" as="geometry"/></mxCell>
        <mxCell id="e1prod" value="E1 can form both E and Z alkene isomers." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f0d9;strokeColor=#2e7d32;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="820" y="930" width="280" height="50" as="geometry"/></mxCell>
        <mxCell id="e2prod" value="E2 forms Hofmann or Zaitsev alkene products depending on base and sterics." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f0d9;strokeColor=#2e7d32;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="820" y="1010" width="330" height="60" as="geometry"/></mxCell>
        <mxCell id="pi" value="Pi systems react according to nucleophile/electrophile role." parent="layer1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b38b00;fontFamily=Verdana;fontSize=13;strokeWidth=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1"><mxGeometry x="1260" y="80" width="360" height="70" as="geometry"/></mxCell>
        <mxCell id="alkene_e" value="Alkenes act as nucleophiles toward electrophiles." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4d6;strokeColor=#c65911;fontFamily=Verdana;fontSize=12;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="1240" y="190" width="330" height="55" as="geometry"/></mxCell>
        <mxCell id="alkene_e2" value="Adding two equivalents of electrophile adds across the former pi bond." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f0d9;strokeColor=#2e7d32;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="1600" y="190" width="360" height="55" as="geometry"/></mxCell>
        <mxCell id="aromatic_e" value="A nucleophilic aromatic carbon can add an electrophile." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4d6;strokeColor=#c65911;fontFamily=Verdana;fontSize=12;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="1240" y="280" width="330" height="55" as="geometry"/></mxCell>
        <mxCell id="aromatic_n" value="An electrophilic aromatic carbon can add a nucleophile." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4d6;strokeColor=#c65911;fontFamily=Verdana;fontSize=12;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="1240" y="370" width="330" height="55" as="geometry"/></mxCell>
        <mxCell id="redox" value="Organic redox is identified by bonds to oxygen/halogens versus hydrogen." parent="layer1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b38b00;fontFamily=Verdana;fontSize=13;strokeWidth=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1"><mxGeometry x="1260" y="560" width="390" height="80" as="geometry"/></mxCell>
        <mxCell id="oxidation" value="Oxidation means gaining bonds to oxygen/halogens or losing bonds to hydrogen." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#a61c2a;fontFamily=Verdana;fontSize=12;strokeWidth=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1"><mxGeometry x="1240" y="690" width="390" height="65" as="geometry"/></mxCell>
        <mxCell id="reduction" value="Reduction means gaining bonds to hydrogen or losing bonds to oxygen/halogens." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f0d9;strokeColor=#2e7d32;fontFamily=Verdana;fontSize=12;strokeWidth=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1"><mxGeometry x="1240" y="790" width="390" height="65" as="geometry"/></mxCell>
        <mxCell id="control" value="Kinetic versus thermodynamic control predicts product distribution." parent="layer1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b38b00;fontFamily=Verdana;fontSize=13;strokeWidth=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1"><mxGeometry x="1260" y="940" width="380" height="70" as="geometry"/></mxCell>
        <mxCell id="kinetic" value="Kinetic control favors the faster, less stable, less substituted product." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#0066cc;fontFamily=Verdana;fontSize=12;strokeWidth=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1"><mxGeometry x="1240" y="1060" width="380" height="60" as="geometry"/></mxCell>
        <mxCell id="kinetic_cond" value="Kinetic control is favored by cold temperature and bulky base such as LDA." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#0066cc;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="1640" y="1060" width="360" height="60" as="geometry"/></mxCell>
        <mxCell id="thermo" value="Thermodynamic control favors the more stable, more substituted product." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f0d9;strokeColor=#2e7d32;fontFamily=Verdana;fontSize=12;strokeWidth=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1"><mxGeometry x="1240" y="1160" width="380" height="60" as="geometry"/></mxCell>
        <mxCell id="thermo_cond" value="Thermodynamic control is favored by warm temperature and a strong small base." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f0d9;strokeColor=#2e7d32;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="1640" y="1160" width="360" height="60" as="geometry"/></mxCell>
        <mxCell id="reagents" value="Oxidizing and reducing agents convert alcohols and carbonyls predictably." parent="layer1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#b38b00;fontFamily=Verdana;fontSize=13;strokeWidth=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1"><mxGeometry x="820" y="1220" width="430" height="70" as="geometry"/></mxCell>
        <mxCell id="pcc1" value="PCC oxidizes primary alcohols to aldehydes." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#a61c2a;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="520" y="1350" width="350" height="58" as="geometry"/></mxCell>
        <mxCell id="pcc2" value="PCC oxidizes secondary alcohols to ketones." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#a61c2a;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="520" y="1430" width="350" height="58" as="geometry"/></mxCell>
        <mxCell id="pcc3" value="PCC does not oxidize alcohols all the way to carboxylic acids." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#a61c2a;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="520" y="1510" width="350" height="58" as="geometry"/></mxCell>
        <mxCell id="mncr1" value="Chromium or manganese oxidants can oxidize primary alcohols to carboxylic acids." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#a61c2a;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="900" y="1350" width="350" height="58" as="geometry"/></mxCell>
        <mxCell id="mncr2" value="Chromium or manganese oxidants oxidize secondary alcohols to ketones." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#a61c2a;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="900" y="1430" width="350" height="58" as="geometry"/></mxCell>
        <mxCell id="tert" value="Tertiary alcohols resist oxidation because there is no hydrogen to remove." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e6f2ff;strokeColor=#0066cc;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="900" y="1510" width="350" height="58" as="geometry"/></mxCell>
        <mxCell id="nabh4" value="NaBH4 reduces aldehydes to primary alcohols and ketones to secondary alcohols." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f0d9;strokeColor=#2e7d32;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="1280" y="1350" width="350" height="58" as="geometry"/></mxCell>
        <mxCell id="lialh4" value="LiAlH4 reduces carboxylic acids, aldehydes, and ketones to alcohols." parent="layer2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e2f0d9;strokeColor=#2e7d32;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;" vertex="1"><mxGeometry x="1280" y="1430" width="350" height="58" as="geometry"/></mxCell>
        <mxCell id="traps" value="Common traps from this Anki section:
SN1/SN2 numbers name molecularity, not number of steps.
SN1 forms a carbocation; SN2 has no intermediate.
Polar protic helps SN1, polar aprotic helps SN2.
Oxidation/reduction can be tracked by H versus O/halogen bonds.
Kinetic product forms faster; thermodynamic product is more stable." parent="layer4" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8d7da;strokeColor=#a61c2a;fontFamily=Verdana;fontSize=11;strokeWidth=2;align=center;verticalAlign=middle;fontStyle=1;" vertex="1"><mxGeometry x="80" y="1240" width="380" height="210" as="geometry"/></mxCell>
